{
  "name": "house-of-glory-church-app",
  "version": "1.0.0",
  "description": "House of Glory Church Management Application",
  "main": "main.js",
  "author": "House of Glory",
  "license": "MIT",
  "scripts": {
    "start": "electronmon .",
    "dev": "electronmon .",
    "start:prod": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir"
  },
  "dependencies": {
    "expo": "^55.0.4",
    "firebase": "^10.14.1"
  },
  "devDependencies": {
    "electron": "^32.2.5",
    "electron-builder": "^25.1.8",
    "electronmon": "^2.0.4"
  },
  "build": {
    "appId": "com.houseofglory.churchapp",
    "productName": "House of Glory Church App",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
